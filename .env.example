# ──────────────────────────────────────────────
# Global Docker environment template
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# ── Environment ────────────────────────────────
NODE_ENV=development

# ── Database ───────────────────────────────────
MYSQL_ROOT_PASSWORD=your-db-root-password
MYSQL_HOST=mariadb
MYSQL_INTERNAL_PORT=3306
MARIADB_HOST_PORT=3307
USERS_DB=users
SESSIONS_DB=sessions

# ── Auth ───────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY=7d

# ── Google OAuth ───────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:6024/api/oauth/google/callback

# ── URLs ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173
REST_API_URL=http://localhost:3001

# ── Service ports ──────────────────────────────
REST_API_PORT=3001
USERS_API_PORT=6024
SESSIONS_API_PORT=6023
GIT_AGENT_PORT=6025
FRONTEND_PORT=5173
DOCS_PORT=6054

# ── Git agent ──────────────────────────────────
GIT_AGENT_REPOS_DIR=/app/repos
