PORT=6025
# Must be 0.0.0.0 inside containers so other services on the docker network
# can reach this one. 127.0.0.1 will silently break service-to-service calls.
BIND_ADDR=0.0.0.0
JWT_SECRET="change-me-to-a-long-random-secret"
REPOS_DIR="./repos"
# CORS_ALLOWED_ORIGINS="https://your-frontend.com,https://app.example.com"
