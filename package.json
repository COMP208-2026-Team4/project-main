{
  "name": "cone",
  "version": "0.1.0",
  "description": "Cone -> lightweight Git hosting and productivity platform (COMP208 Team 4)",
  "private": true,
  "workspaces": [
    "docs",
    "frontend",
    "rest-api",
    "sessions-api",
    "users-api"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev": "pm2 start ecosystem.config.js",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:rest-api": "npm run dev --workspace=rest-api",
    "dev:sessions-api": "npm run dev --workspace=sessions-api",
    "dev:users-api": "npm run dev --workspace=users-api",
    "dev:docs": "npm run start --workspace=docs",
    "build:git-agent": "cd git-agent && cargo build --release",
    "test:git-agent": "cd git-agent && cargo test",
    "test": "npm run test --workspaces --if-present"
  }
}
