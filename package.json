{
  "name": "cone",
  "version": "0.1.0",
  "description": "Cone -> lightweight Git hosting and productivity platform (COMP208 Team 4)",
  "private": true,
  "scripts": {
    "docker": "docker compose up -d --build",
    "install:all": "npm install",
    "build:frontend": "cd frontend && npm run build",
    "build:git-agent": "cd git-agent && cargo build --release",
    "test:git-agent": "cd git-agent && cargo test",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "effect": "^3.20.0"
  }
}
